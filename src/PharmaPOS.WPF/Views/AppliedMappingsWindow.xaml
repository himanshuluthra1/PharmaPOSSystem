<Window x:Class="PharmaPOS.WPF.Views.AppliedMappingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Applied medicine mappings" Height="560" Width="980"
        WindowStartupLocation="CenterOwner"
        MinHeight="420" MinWidth="760"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Saved MedWin ↔ OneMG mappings" FontSize="18" FontWeight="Bold" />
        <TextBlock Grid.Row="1" Opacity="0.7" Margin="0,4,0,12" TextWrapping="Wrap"
                   Text="These mappings are stored in the database and can be reused by other tools or integrations." />

        <DockPanel Grid.Row="2">
            <TextBox DockPanel.Dock="Top" materialDesign:HintAssist.Hint="Filter by MedWin or OneMG name / id..."
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Text="{Binding AppliedMappingsFilter, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
            <DataGrid ItemsSource="{Binding AppliedMappings}" AutoGenerateColumns="False"
                      CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column"
                      ScrollViewer.CanContentScroll="False"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="MedWin" Binding="{Binding MedWinMedicineName}" Width="*" MinWidth="140" />
                    <DataGridTextColumn Header="MedWin ID" Binding="{Binding MedWinId}" Width="80" />
                    <DataGridTextColumn Header="OneMG" Binding="{Binding OneMgMedicineName}" Width="*" MinWidth="140" />
                    <DataGridTextColumn Header="OneMG ID" Binding="{Binding OneMgCatalogId}" Width="90" />
                    <DataGridTextColumn Header="Mapped" Binding="{Binding MappedAtUtc, StringFormat=yyyy-MM-dd HH:mm}" Width="130" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <TextBlock DockPanel.Dock="Left" Text="{Binding AppliedMappingsStatus}" Opacity="0.6" VerticalAlignment="Center" />
            <Button DockPanel.Dock="Right" Content="Close" Style="{StaticResource MaterialDesignRaisedButton}"
                    IsDefault="True" Click="CloseButton_Click" MinWidth="90" />
        </DockPanel>
    </Grid>
</Window>
