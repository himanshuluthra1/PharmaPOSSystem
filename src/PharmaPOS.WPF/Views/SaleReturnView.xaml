<UserControl x:Class="PharmaPOS.WPF.Views.SaleReturnView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:salesVm="clr-namespace:PharmaPOS.WPF.ViewModels.Sales"
             d:DataContext="{d:DesignInstance Type=salesVm:SaleReturnViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="760"
             Focusable="True"
             PreviewKeyDown="SaleReturnView_PreviewKeyDown">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Search bar -->
        <materialDesign:Card Grid.Row="0" Margin="0,0,0,8" UniformCornerRadius="10" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" Margin="0,0,8,0"
                          ItemsSource="{Binding CriteriaOptions}"
                          SelectedItem="{Binding SelectedCriteria}"
                          DisplayMemberPath="Label"
                          materialDesign:HintAssist.Hint="Search by"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                <TextBox x:Name="SearchBox" Grid.Column="1" Margin="0,0,8,0"
                         materialDesign:HintAssist.Hint="{Binding SearchHint}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="2" Margin="0,0,8,0"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Padding="16,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Margin="0,0,6,0" />
                        <TextBlock Text="Search" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="3"
                        Command="{Binding LoadInvoiceCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Padding="16,8"
                        ToolTip="Load selected invoice (Enter)">
                    <TextBlock Text="Load Invoice" />
                </Button>
            </Grid>
        </materialDesign:Card>

        <!-- Search results -->
        <materialDesign:Card Grid.Row="1" Margin="0,0,0,8" UniformCornerRadius="10" Padding="8"
                             MaxHeight="150"
                             Visibility="{Binding HasSearchResults, Converter={StaticResource BoolToVisibility}}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Matching invoices" FontWeight="SemiBold" Margin="4,0,0,6" />
                <DataGrid ItemsSource="{Binding SearchResults}"
                          SelectedIndex="{Binding SelectedSearchIndex, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          MouseDoubleClick="SearchGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Invoice #" Binding="{Binding InvoiceNumber}" Width="140" />
                        <DataGridTextColumn Header="Date" Binding="{Binding InvoiceDateLabel}" Width="150" />
                        <DataGridTextColumn Header="Customer" Binding="{Binding CustomerLabel}" Width="*" MinWidth="140" />
                        <DataGridTextColumn Header="Phone" Binding="{Binding CustomerPhone}" Width="110" />
                        <DataGridTextColumn Header="Amount" Binding="{Binding GrandTotal, StringFormat=N2}" Width="90" />
                        <DataGridTextColumn Header="Cashier" Binding="{Binding CashierName}" Width="100" />
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusLabel}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </materialDesign:Card>

        <!-- Main split: invoice lines | return summary -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="560" />
                <ColumnDefinition Width="340" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <!-- Invoice lines + inspection -->
            <materialDesign:Card Grid.Column="0" Margin="0,0,6,0" UniformCornerRadius="10" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Invoice Items" FontSize="18" FontWeight="Bold" />
                            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Opacity="0.85">
                                <Run Text="{Binding InvoiceNumber, StringFormat=Invoice: {0}, Mode=OneWay}" />
                                <Run Text="  ·  " />
                                <Run Text="{Binding InvoiceDateLabel, Mode=OneWay}" />
                                <Run Text="  ·  " />
                                <Run Text="{Binding CustomerName, StringFormat=Customer: {0}, Mode=OneWay}" />
                                <Run Text="  ·  " />
                                <Run Text="{Binding InvoiceStatus, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Button Command="{Binding ReturnEntireInvoiceCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="0,0,8,0" Padding="12,6"
                                    ToolTip="Return all eligible items">
                                <TextBlock Text="Return Entire Invoice" />
                            </Button>
                            <Button Command="{Binding ClearCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Padding="12,6">
                                <TextBlock Text="Clear" />
                            </Button>
                        </StackPanel>
                    </DockPanel>

                    <DataGrid x:Name="LinesGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding Lines}"
                              SelectedItem="{Binding SelectedLine, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single"
                              EnableRowVirtualization="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              materialDesign:DataGridAssist.CellPadding="6,4">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Return"
                                                    Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="60" />
                            <DataGridTextColumn Header="Medicine" Binding="{Binding MedicineName}" Width="*" MinWidth="160" IsReadOnly="True" />
                            <DataGridTextColumn Header="Batch" Binding="{Binding BatchNumber}" Width="90" IsReadOnly="True" />
                            <DataGridTextColumn Header="Expiry" Binding="{Binding ExpiryLabel}" Width="70" IsReadOnly="True" />
                            <DataGridTextColumn Header="MRP" Binding="{Binding Mrp, StringFormat=N2}" Width="70" IsReadOnly="True" />
                            <DataGridTextColumn Header="Sold" Binding="{Binding SoldQuantity, StringFormat=N0}" Width="50" IsReadOnly="True" />
                            <DataGridTextColumn Header="Already" Binding="{Binding AlreadyReturnedQuantity, StringFormat=N0}" Width="60" IsReadOnly="True" />
                            <DataGridTextColumn Header="Avail" Binding="{Binding AvailableReturnQuantity, StringFormat=N0}" Width="50" IsReadOnly="True" />
                            <DataGridTextColumn Header="Return Qty"
                                                Binding="{Binding ReturnQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="80"
                                                IsReadOnly="False" />
                            <DataGridTemplateColumn Header="Reason" Width="170" MinWidth="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.ReturnReasons, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  SelectedValue="{Binding ReturnReasonId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Id"
                                                  DisplayMemberPath="Name"
                                                  IsEditable="False" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridCheckBoxColumn Header="Saleable"
                                                    Binding="{Binding IsSaleable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="70" />
                            <DataGridTextColumn Header="Validation" Binding="{Binding ValidationMessage}" Width="140" MinWidth="100" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Inspection for selected line -->
                    <Border Grid.Row="2" Margin="0,10,0,0" Padding="10"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1" CornerRadius="6"
                            Visibility="{Binding HasSelectedLine, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Physical inspection" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <TextBlock Text="{Binding SelectedLine.MedicineName}" TextTrimming="CharacterEllipsis" Margin="0,0,0,6" />
                                <CheckBox Content="Seal intact" IsChecked="{Binding SelectedLine.SealIntact}" Margin="0,0,0,4" />
                                <CheckBox Content="Packaging damaged" IsChecked="{Binding SelectedLine.PackagingDamaged}" Margin="0,0,0,4" />
                                <CheckBox Content="Expiry valid" IsChecked="{Binding SelectedLine.ExpiryValid}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="12,0">
                                <TextBlock Text="Batch scan (optional)" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <TextBox materialDesign:HintAssist.Hint="Scanned batch number"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding SelectedLine.ScannedBatchNumber, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,8" />
                                <CheckBox Content="Approve batch mismatch"
                                          IsChecked="{Binding SelectedLine.BatchMismatchApproved}"
                                          Visibility="{Binding SelectedLine.BatchMismatch, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="12,0,0,0">
                                <TextBlock Text="Reason remarks" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <TextBox materialDesign:HintAssist.Hint="Required when reason is Other"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding SelectedLine.ReasonRemarks, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="56" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </materialDesign:Card>

            <!-- Refund panel -->
            <materialDesign:Card Grid.Column="1" UniformCornerRadius="10" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Return Summary" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Taxable" Opacity="0.7" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RefundSubTotal, StringFormat=N2}" />
                            <TextBlock Grid.Row="1" Text="Discount reversal" Opacity="0.7" Margin="0,4,0,0" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,4,0,0" Text="{Binding RefundDiscount, StringFormat=N2}" />
                            <TextBlock Grid.Row="2" Text="GST reversal" Opacity="0.7" Margin="0,4,0,0" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,4,0,0" Text="{Binding RefundTax, StringFormat=N2}" />
                            <Separator Grid.Row="3" Grid.ColumnSpan="2" Margin="0,8" />
                            <TextBlock Grid.Row="4" Text="Refund Total" FontWeight="Bold" FontSize="16" />
                            <TextBlock Grid.Row="4" Grid.Column="1" FontWeight="Bold" FontSize="16"
                                       Text="{Binding RefundGrandTotal, StringFormat=N2}" />
                        </Grid>

                        <ComboBox ItemsSource="{Binding RefundModes}"
                                  SelectedItem="{Binding RefundMode}"
                                  materialDesign:HintAssist.Hint="Refund method"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  Margin="0,0,0,12" />

                        <TextBox materialDesign:HintAssist.Hint="Return remarks (optional)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding Remarks, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48" />

                        <CheckBox Content="Manager policy override"
                                  IsChecked="{Binding ManagerOverride}"
                                  IsEnabled="{Binding CanOverride}"
                                  Margin="0,0,0,8" />
                        <TextBox materialDesign:HintAssist.Hint="Override reason (required if override)"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding ManagerOverrideReason, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"
                                 Visibility="{Binding ManagerOverride, Converter={StaticResource BoolToVisibility}}" />

                        <TextBlock Text="Manager approval may be required for expired window or high-value returns."
                                   FontSize="11" Opacity="0.65" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Visibility="{Binding RequiresManagerApproval, Converter={StaticResource BoolToVisibility}}" />

                        <Button Command="{Binding ProcessReturnCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                HorizontalAlignment="Stretch"
                                Padding="0,12"
                                Margin="0,0,0,8">
                            <TextBlock Text="Create Return (F9)" FontWeight="SemiBold" />
                        </Button>

                        <Button Command="{Binding PrintLastCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                HorizontalAlignment="Stretch"
                                Padding="0,10">
                            <TextBlock Text="Reprint Last Return" />
                        </Button>

                        <TextBlock Text="{Binding StatusMessage}" Margin="0,12,0,0"
                                   FontSize="12" Opacity="0.75" TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </materialDesign:Card>
        </Grid>

        <TextBlock Grid.Row="3" Margin="4,6,0,0" FontSize="11" Opacity="0.55"
                   Text="F3 Search · Enter Load · F9 Process Return · Tick Return, set qty, then Create Return" />
    </Grid>
</UserControl>
