<Window x:Class="PharmaPOS.WPF.Views.PurchaseSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Search Purchases" Height="820" Width="1100"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Search Purchases" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />

        <TextBox x:Name="SupplierFilterBox" Grid.Row="1"
                 materialDesign:HintAssist.Hint="Supplier (default All)"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Text="{Binding SupplierFilterText, UpdateSourceTrigger=PropertyChanged}"
                 PreviewKeyDown="SupplierFilterBox_PreviewKeyDown"
                 Margin="0,0,0,8" />

        <TextBlock Grid.Row="2" Text="{Binding Hint}" FontSize="12" Opacity="0.7"
                   Margin="0,0,0,6"
                   Visibility="{Binding Hint, Converter={StaticResource StringToVisibility}}" />

        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" MaxHeight="140" />
                <RowDefinition Height="1.4*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="160" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Margin="0,0,0,8"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="1" CornerRadius="4"
                    Visibility="{Binding ShowSupplierSuggestions, Converter={StaticResource BoolToVisibility}}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Supplier suggestions"
                               FontSize="11" Opacity="0.6" Margin="8,6,8,4" />
                    <ListBox x:Name="SupplierSuggestionList"
                             ItemsSource="{Binding SupplierSuggestions}"
                             SelectedIndex="{Binding SupplierSuggestionIndex, Mode=TwoWay}"
                             MaxHeight="90" BorderThickness="0"
                             Focusable="False"
                             PreviewKeyDown="SupplierSuggestionList_PreviewKeyDown"
                             PreviewMouseLeftButtonUp="SupplierSuggestionList_PreviewMouseLeftButtonUp">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Padding="8,4">
                                    <Run Text="{Binding Name}" FontWeight="SemiBold" />
                                    <Run Text="{Binding Phone, StringFormat=' ({0})'}" FontSize="11" />
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <DockPanel Grid.Row="1">
                <TextBlock DockPanel.Dock="Top" Text="Purchase invoices"
                           FontSize="11" Opacity="0.6" Margin="0,0,0,4" />
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="BillsGrid" Grid.Row="0"
                              ItemsSource="{Binding Bills}"
                              SelectedIndex="{Binding SelectedBillIndex, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              PreviewKeyDown="BillsGrid_PreviewKeyDown"
                              MouseDoubleClick="BillsGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Invoice #" Binding="{Binding InvoiceNumber}" Width="130" />
                            <DataGridTextColumn Header="Supplier" Binding="{Binding SupplierName}" Width="*" MinWidth="180" />
                            <DataGridTextColumn Header="Date" Binding="{Binding InvoiceDateLabel}" Width="170" />
                            <DataGridTextColumn Header="Amount" Binding="{Binding GrandTotal, StringFormat=N2}" Width="100" />
                            <DataGridTextColumn Header="Items" Binding="{Binding ItemCount}" Width="70" />
                            <DataGridTextColumn Header="Payment Due" Binding="{Binding PaymentDue, StringFormat=N2}" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Row="1"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="0,1,0,0"
                            Background="{DynamicResource MaterialDesignChipBackground}"
                            Padding="8,10"
                            Visibility="{Binding ShowBillTotals, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" MinWidth="180" />
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Grid.ColumnSpan="3"
                                       Text="Total Balance" FontWeight="Bold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3"
                                       Text="{Binding TotalAmount, StringFormat=N2}"
                                       FontWeight="SemiBold" HorizontalAlignment="Right" Opacity="0.85" />
                            <TextBlock Grid.Column="5"
                                       Text="{Binding TotalBalance, StringFormat=N2}"
                                       FontWeight="Bold" HorizontalAlignment="Right" />
                        </Grid>
                    </Border>
                </Grid>
            </DockPanel>

            <TextBlock Grid.Row="2" Text="Invoice lines (drill-down)"
                       FontSize="11" Opacity="0.6" Margin="0,10,0,4"
                       Visibility="{Binding ShowInvoiceLines, Converter={StaticResource BoolToVisibility}}" />

            <DataGrid Grid.Row="3"
                      ItemsSource="{Binding InvoiceLines}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      Visibility="{Binding ShowInvoiceLines, Converter={StaticResource BoolToVisibility}}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Medicine" Binding="{Binding MedicineName}" Width="2*" MinWidth="160" />
                    <DataGridTextColumn Header="Batch" Binding="{Binding BatchNumber}" Width="100" />
                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="60" />
                    <DataGridTextColumn Header="Free" Binding="{Binding FreeQuantity}" Width="60" />
                    <DataGridTextColumn Header="Cost" Binding="{Binding PurchasePrice, StringFormat=N2}" Width="80" />
                    <DataGridTextColumn Header="Amount" Binding="{Binding LineTotal, StringFormat=N2}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock Text="↑↓ navigate  •  Enter open purchase  •  Esc cancel" Opacity="0.5"
                       VerticalAlignment="Center" Margin="0,0,16,0" FontSize="11" />
            <Button Content="Cancel" Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,0" IsCancel="True" />
            <Button Content="Open Purchase" Style="{StaticResource MaterialDesignRaisedButton}"
                    IsDefault="True" Click="OpenPurchaseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
