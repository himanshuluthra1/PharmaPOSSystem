<UserControl x:Class="PharmaPOS.WPF.Views.PlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:PharmaPOS.WPF.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:PlaceholderViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="8">
        <materialDesign:Card UniformCornerRadius="12" Padding="32"
                             VerticalAlignment="Top"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ToolboxOutline" Width="34" Height="34"
                                             Foreground="#26A69A" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Title}" FontSize="26" FontWeight="Bold"
                               Margin="14,0,0,0" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                           Opacity="0.75" Margin="0,14,0,0" FontSize="14" MaxWidth="720"
                           HorizontalAlignment="Left" />

                <materialDesign:Chip Content="Scaffolded - implementation coming in a later phase"
                                     IconBackground="#FFA726" Margin="0,20,0,0"
                                     HorizontalAlignment="Left">
                    <materialDesign:Chip.Icon>
                        <materialDesign:PackIcon Kind="Wrench" />
                    </materialDesign:Chip.Icon>
                </materialDesign:Chip>

                <TextBlock Text="Planned features" FontSize="16" FontWeight="SemiBold"
                           Margin="0,28,0,10" />
                <ItemsControl ItemsSource="{Binding PlannedFeatures}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <materialDesign:PackIcon Kind="CheckCircleOutline"
                                                         Foreground="#26A69A"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="{Binding}" Margin="10,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
