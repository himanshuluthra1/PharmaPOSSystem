<UserControl x:Class="PharmaPOS.WPF.Views.AccountingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:acctVm="clr-namespace:PharmaPOS.WPF.ViewModels.Accounting"
             d:DataContext="{d:DesignInstance Type=acctVm:AccountingViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700">
    <UserControl.Resources>
        <Style x:Key="AcctDataGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="RowHeight" Value="30" />
            <Setter Property="materialDesign:DataGridAssist.CellPadding" Value="6,3" />
        </Style>
        <Style x:Key="AcctOutlinedBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="AcctOutlinedCombo" TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="AcctToolbarButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Opacity" Value="0.55" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="4">
        <materialDesign:Card UniformCornerRadius="8" Padding="10,8"
                             materialDesign:ElevationAssist.Elevation="Dp1">
            <DockPanel>
                <!-- Header -->
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Button DockPanel.Dock="Right" Command="{Binding RefreshCommand}"
                            Style="{StaticResource AcctToolbarButton}" Padding="8,4" Height="30">
                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" />
                    </Button>
                    <TextBlock Text="Accounting" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center" />
                </DockPanel>

                <!-- KPI strip -->
                <UniformGrid DockPanel.Dock="Top" Columns="4" Margin="0,0,0,8">
                    <StackPanel Margin="4,0">
                        <TextBlock Text="Receivables" Style="{StaticResource KpiLabel}" />
                        <TextBlock Text="{Binding Summary.TotalReceivables, Converter={StaticResource Currency}}"
                                   Style="{StaticResource KpiValue}" />
                        <TextBlock Text="{Binding Summary.ReceivableParties, StringFormat='{}{0} parties'}"
                                   FontSize="10" Opacity="0.45" />
                    </StackPanel>
                    <StackPanel Margin="4,0">
                        <TextBlock Text="Payables" Style="{StaticResource KpiLabel}" />
                        <TextBlock Text="{Binding Summary.TotalPayables, Converter={StaticResource Currency}}"
                                   Style="{StaticResource KpiValue}" />
                        <TextBlock Text="{Binding Summary.PayableParties, StringFormat='{}{0} parties'}"
                                   FontSize="10" Opacity="0.45" />
                    </StackPanel>
                    <StackPanel Margin="4,0">
                        <TextBlock Text="Cash in hand" Style="{StaticResource KpiLabel}" />
                        <TextBlock Text="{Binding Summary.CashInHand, Converter={StaticResource Currency}}"
                                   Style="{StaticResource KpiValue}" />
                    </StackPanel>
                    <StackPanel Margin="4,0">
                        <TextBlock Text="Bank balance" Style="{StaticResource KpiLabel}" />
                        <TextBlock Text="{Binding Summary.BankBalance, Converter={StaticResource Currency}}"
                                   Style="{StaticResource KpiValue}" />
                    </StackPanel>
                </UniformGrid>

                <TabControl SelectedIndex="{Binding SelectedTab}" Padding="0">
                    <!-- PARTY LEDGERS -->
                    <TabItem Header="Parties" Padding="10,4">
                        <Grid DataContext="{Binding PartyLedger}" Margin="0,6,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Command="{Binding DataContext.RecordPaymentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Style="{StaticResource AcctToolbarButton}" Margin="4,0,0,0"
                                            ToolTip="Record supplier payment">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CashMinus" Width="14" Height="14" VerticalAlignment="Center" />
                                            <TextBlock Text="Payment" Margin="4,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding DataContext.RecordReceiptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Style="{StaticResource AcctToolbarButton}" Margin="4,0,0,0"
                                            ToolTip="Record customer receipt">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CashPlus" Width="14" Height="14" VerticalAlignment="Center" />
                                            <TextBlock Text="Receipt" Margin="4,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource MaterialDesignIconButton}"
                                            Width="30" Height="30" Margin="4,0,0,0" ToolTip="Refresh">
                                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" />
                                    </Button>
                                </StackPanel>
                                <ComboBox Width="160" Margin="0,0,6,0"
                                          ItemsSource="{Binding KindOptions}"
                                          SelectedItem="{Binding SelectedKind}"
                                          DisplayMemberPath="Label"
                                          Style="{StaticResource AcctOutlinedCombo}" />
                                <TextBox materialDesign:HintAssist.Hint="Search party..."
                                         Style="{StaticResource AcctOutlinedBox}"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.35*" MinWidth="280" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" MinWidth="240" />
                                </Grid.ColumnDefinitions>

                                <DataGrid Grid.Column="0" Style="{StaticResource AcctDataGrid}"
                                          ItemsSource="{Binding Parties}" SelectedItem="{Binding SelectedParty}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Party" Binding="{Binding Name}" Width="*" MinWidth="140" />
                                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="100" />
                                        <DataGridTextColumn Header="Outstanding" Binding="{Binding OutstandingBalance, StringFormat=N2}" Width="95" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Grid.Column="1" Width="1" Margin="6,0"
                                        Background="{DynamicResource MaterialDesignDivider}" />

                                <DockPanel Grid.Column="2">
                                    <TextBlock DockPanel.Dock="Top" Text="Open bills" FontSize="11" FontWeight="SemiBold"
                                               Opacity="0.5" Margin="0,0,0,4" />
                                    <DataGrid Style="{StaticResource AcctDataGrid}" ItemsSource="{Binding Bills}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Invoice" Binding="{Binding InvoiceNumber}" Width="110" />
                                            <DataGridTextColumn Header="Date" Binding="{Binding InvoiceDateLabel}" Width="90" />
                                            <DataGridTextColumn Header="Due" Binding="{Binding BalanceDue, StringFormat=N2}" Width="75" />
                                            <DataGridTextColumn Header="Total" Binding="{Binding GrandTotal, StringFormat=N2}" Width="75" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- VOUCHERS -->
                    <TabItem Header="Vouchers" Padding="10,4"
                             Visibility="{Binding CanCreateVouchers, Converter={StaticResource BoolToVisibility}}">
                        <Grid DataContext="{Binding Vouchers}" Margin="0,6,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" Margin="0,0,6,0"
                                          ItemsSource="{Binding KindOptions}"
                                          SelectedItem="{Binding SelectedKind}"
                                          DisplayMemberPath="Label"
                                          materialDesign:HintAssist.Hint="Type"
                                          Style="{StaticResource AcctOutlinedCombo}" />
                                <TextBox Grid.Column="1" Margin="0,0,6,0" IsReadOnly="True"
                                         materialDesign:HintAssist.Hint="Voucher #"
                                         Style="{StaticResource AcctOutlinedBox}"
                                         Text="{Binding VoucherNumber, Mode=OneWay}" />
                                <DatePicker Grid.Column="2" Margin="0,0,6,0"
                                            materialDesign:HintAssist.Hint="Date"
                                            SelectedDate="{Binding EntryDate}" />
                                <TextBox Grid.Column="3"
                                         materialDesign:HintAssist.Hint="Narration"
                                         Style="{StaticResource AcctOutlinedBox}"
                                         Text="{Binding Narration, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <StackPanel Grid.Row="1" Margin="0,0,0,8"
                                        Visibility="{Binding ShowPartyFields, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox materialDesign:HintAssist.Hint="{Binding PartyHint}"
                                             Style="{StaticResource AcctOutlinedBox}"
                                             Text="{Binding PartySearchText, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Column="1" Text="{Binding PartyOutstandingLabel}" FontSize="11"
                                               Opacity="0.65" VerticalAlignment="Center" Margin="12,0,0,0"
                                               Visibility="{Binding PartyOutstandingLabel, Mode=OneWay, Converter={StaticResource StringToVisibility}}" />
                                </Grid>
                                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1"
                                        CornerRadius="4" MaxHeight="100" Margin="0,4,0,0"
                                        Visibility="{Binding ShowPartySuggestions, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <ListBox ItemsSource="{Binding PartySuggestions}"
                                             PreviewMouseLeftButtonUp="PartySuggestionList_MouseLeftButtonUp">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="6,2">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" />
                                                    <TextBlock Text="{Binding OutstandingBalance, StringFormat=' — {0:N2}'}"
                                                               Margin="6,0,0,0" Opacity="0.6" FontSize="12" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </StackPanel>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" Margin="0,0,6,0"
                                          ItemsSource="{Binding ExpenseAccounts}"
                                          SelectedItem="{Binding SelectedExpenseAccount}"
                                          DisplayMemberPath="DisplayLabel"
                                          materialDesign:HintAssist.Hint="Expense account"
                                          Style="{StaticResource AcctOutlinedCombo}"
                                          Visibility="{Binding ShowExpenseFields, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                <ComboBox Grid.Column="1" Margin="0,0,6,0"
                                          ItemsSource="{Binding CashAccounts}"
                                          SelectedItem="{Binding SelectedCashAccount}"
                                          DisplayMemberPath="DisplayLabel"
                                          materialDesign:HintAssist.Hint="Cash / Bank"
                                          Style="{StaticResource AcctOutlinedCombo}" />
                                <TextBox Grid.Column="2" Margin="0,0,6,0"
                                         materialDesign:HintAssist.Hint="Amount"
                                         Style="{StaticResource AcctOutlinedBox}"
                                         Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="3" Command="{Binding NewCommand}"
                                        Style="{StaticResource AcctToolbarButton}" Margin="0,0,4,0">
                                    <TextBlock Text="Clear" />
                                </Button>
                                <Button Grid.Column="4" Command="{Binding SaveCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Padding="12,4" Height="32">
                                    <TextBlock Text="Save" FontSize="12" />
                                </Button>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- CASH BOOK -->
                    <TabItem Header="Cash Book" Padding="10,4">
                        <Grid DataContext="{Binding CashBook}" Margin="0,6,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                <Button DockPanel.Dock="Right" Command="{Binding RefreshCommand}"
                                        Style="{StaticResource MaterialDesignIconButton}" Width="30" Height="30"
                                        ToolTip="Refresh">
                                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" />
                                </Button>
                                <TextBlock Text="Cash in hand movements" FontSize="12" Opacity="0.5" VerticalAlignment="Center" />
                            </DockPanel>
                            <DataGrid Grid.Row="1" Style="{StaticResource AcctDataGrid}" ItemsSource="{Binding Items}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding EntryDateLabel}" Width="90" />
                                    <DataGridTextColumn Header="Voucher" Binding="{Binding VoucherNumber}" Width="120" />
                                    <DataGridTextColumn Header="Narration" Binding="{Binding Narration}" Width="*" MinWidth="140" />
                                    <DataGridTextColumn Header="Dr" Binding="{Binding Debit, StringFormat=N2}" Width="80" />
                                    <DataGridTextColumn Header="Cr" Binding="{Binding Credit, StringFormat=N2}" Width="80" />
                                    <DataGridTextColumn Header="Balance" Binding="{Binding RunningBalance, StringFormat=N2}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <!-- JOURNAL -->
                    <TabItem Header="Journal" Padding="10,4"
                             Visibility="{Binding CanViewJournal, Converter={StaticResource BoolToVisibility}}">
                        <Grid DataContext="{Binding Journal}" Margin="0,6,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="1.2*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="120" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                <Button DockPanel.Dock="Right" Command="{Binding RefreshCommand}"
                                        Style="{StaticResource MaterialDesignIconButton}" Width="30" Height="30"
                                        ToolTip="Refresh">
                                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" />
                                </Button>
                                <TextBox materialDesign:HintAssist.Hint="Search voucher or narration..."
                                         Style="{StaticResource AcctOutlinedBox}"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>

                            <Grid Grid.Row="1" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <DataGrid Grid.Column="0" Style="{StaticResource AcctDataGrid}"
                                          ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Voucher" Binding="{Binding VoucherNumber}" Width="115" />
                                        <DataGridTextColumn Header="Date" Binding="{Binding EntryDateLabel}" Width="85" />
                                        <DataGridTextColumn Header="Type" Binding="{Binding ReferenceType}" Width="80" />
                                        <DataGridTextColumn Header="Amt" Binding="{Binding TotalAmount, StringFormat=N2}" Width="75" />
                                        <DataGridTextColumn Header="Narration" Binding="{Binding Narration}" Width="*" MinWidth="100" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Grid.Column="1" Width="1" Margin="6,0"
                                        Background="{DynamicResource MaterialDesignDivider}" />

                                <DockPanel Grid.Column="2">
                                    <TextBlock DockPanel.Dock="Top" Text="Lines" FontSize="11" FontWeight="SemiBold"
                                               Opacity="0.5" Margin="0,0,0,4" />
                                    <DataGrid Style="{StaticResource AcctDataGrid}" ItemsSource="{Binding Lines}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Account" Binding="{Binding AccountName}" Width="*" MinWidth="100" />
                                            <DataGridTextColumn Header="Dr/Cr" Binding="{Binding EntryTypeLabel}" Width="44" />
                                            <DataGridTextColumn Header="Amt" Binding="{Binding Amount, StringFormat=N2}" Width="75" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Grid>

                            <DockPanel Grid.Row="2" Margin="0,0,0,4">
                                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                                           Text="{Binding TrialTotalsText, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="Trial Balance" FontSize="12" FontWeight="SemiBold" Opacity="0.6" VerticalAlignment="Center" />
                            </DockPanel>

                            <DataGrid Grid.Row="3" Style="{StaticResource AcctDataGrid}" ItemsSource="{Binding TrialBalance}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="60" />
                                    <DataGridTextColumn Header="Account" Binding="{Binding Name}" Width="*" MinWidth="120" />
                                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80" />
                                    <DataGridTextColumn Header="Debit" Binding="{Binding Debit, StringFormat=N2}" Width="90" />
                                    <DataGridTextColumn Header="Credit" Binding="{Binding Credit, StringFormat=N2}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
