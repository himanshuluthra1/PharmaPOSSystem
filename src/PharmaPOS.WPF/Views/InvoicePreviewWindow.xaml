<Window x:Class="PharmaPOS.WPF.Views.InvoicePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Invoice Preview" Height="820" Width="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <DockPanel>
        <materialDesign:ColorZone DockPanel.Dock="Top" Mode="PrimaryMid" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PrintButton" Click="PrintButton_Click"
                        Style="{StaticResource MaterialDesignRaisedLightButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Printer" VerticalAlignment="Center" />
                        <TextBlock Text="Print" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>
                <Button Content="Close" Margin="8,0,0,0" Click="CloseButton_Click"
                        Style="{StaticResource MaterialDesignFlatButton}" />
            </StackPanel>
        </materialDesign:ColorZone>

        <Border Background="#EEEEEE">
            <FlowDocumentScrollViewer x:Name="Viewer" Margin="16"
                                      Background="White"
                                      VerticalScrollBarVisibility="Auto"
                                      Zoom="90" />
        </Border>
    </DockPanel>
</Window>
