<UserControl x:Class="PharmaPOS.WPF.Views.PurchaseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:purchaseVm="clr-namespace:PharmaPOS.WPF.ViewModels.Purchases"
             d:DataContext="{d:DesignInstance Type=purchaseVm:PurchaseViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             PreviewKeyDown="PurchaseView_PreviewKeyDown">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.6*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <materialDesign:Card Grid.Column="0" Margin="4" UniformCornerRadius="12" Padding="16"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Purchase / Goods Receipt" FontSize="20" FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding SearchPurchasesCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Padding="12,8" Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                ToolTip="Search purchases by supplier">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18"
                                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Search" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Grid Width="320">
                        <ToggleButton x:Name="PurchaseSelectorToggle"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      Padding="10,8"
                                      Style="{StaticResource MaterialDesignOutlinedButton}"
                                      Checked="PurchaseSelectorToggle_Checked"
                                      Unchecked="PurchaseSelectorToggle_Unchecked">
                            <Grid>
                                <TextBlock Text="{Binding SelectedPurchase.DisplayLabel, FallbackValue='Select purchase'}"
                                           VerticalAlignment="Center" HorizontalAlignment="Left"
                                           Margin="0,0,20,0" TextTrimming="CharacterEllipsis" />
                                <materialDesign:PackIcon Kind="ChevronDown"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center" Width="18" Height="18" />
                            </Grid>
                        </ToggleButton>
                        <Popup x:Name="PurchasePopup"
                               PlacementTarget="{Binding ElementName=PurchaseSelectorToggle}"
                               Placement="Custom"
                               CustomPopupPlacementCallback="PurchasePopup_PlacementCallback"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               Closed="PurchasePopup_Closed">
                            <Border Background="{DynamicResource MaterialDesignPaper}"
                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="0,4"
                                    Width="720"
                                    MaxHeight="360"
                                    materialDesign:ElevationAssist.Elevation="Dp4">
                                <ListBox x:Name="PurchaseListBox"
                                         ItemsSource="{Binding PurchaseHistory}"
                                         SelectedItem="{Binding SelectedPurchase, Mode=TwoWay}"
                                         Width="712"
                                         HorizontalContentAlignment="Stretch"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         ScrollViewer.CanContentScroll="False"
                                         SelectionChanged="PurchaseListBox_SelectionChanged"
                                         PreviewKeyDown="PurchaseListBox_PreviewKeyDown"
                                         PreviewMouseLeftButtonUp="PurchaseListBox_PreviewMouseLeftButtonUp">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="MinHeight" Value="36" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="12,8" Width="680">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="165" />
                                                    <ColumnDefinition Width="195" />
                                                    <ColumnDefinition Width="*" MinWidth="160" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding InvoiceNumber}"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding BillDateLabel}"
                                                           Margin="16,0,0,0"
                                                           Opacity="0.9"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding BillSupplierLabel}"
                                                           Margin="16,0,0,0"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Popup>
                    </Grid>
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1.4*" />
                        <ColumnDefinition Width="1.2*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MaterialDesignIconButton}"
                                    Command="{Binding ClearSupplierCommand}" ToolTip="Clear supplier">
                                <materialDesign:PackIcon Kind="Close" />
                            </Button>
                            <TextBox x:Name="SupplierSearchBox"
                                     materialDesign:HintAssist.Hint="Search supplier (name / phone)"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding SupplierSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     PreviewKeyDown="SupplierSearchBox_PreviewKeyDown" />
                        </DockPanel>
                        <ListBox x:Name="SupplierResultsList"
                                 ItemsSource="{Binding SupplierResults}"
                                 SelectedIndex="{Binding SupplierSuggestionIndex, Mode=TwoWay}"
                                 MaxHeight="110" Margin="0,4,0,0"
                                 Visibility="{Binding ShowSupplierResults, Converter={StaticResource BoolToVisibility}}"
                                 PreviewKeyDown="SupplierResultsList_PreviewKeyDown"
                                 PreviewMouseLeftButtonUp="SupplierResultsList_PreviewMouseLeftButtonUp">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Padding="4,2">
                                        <Run Text="{Binding Name}" FontWeight="SemiBold" />
                                        <Run Text="{Binding Phone, StringFormat=' ({0})'}" FontSize="11" />
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border Background="{DynamicResource MaterialDesignChipBackground}"
                                CornerRadius="6" Padding="10,6" Margin="0,6,0,0">
                            <TextBlock Text="{Binding SupplierDisplay}" FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>

                    <TextBox Grid.Column="1" Margin="0,0,8,0" VerticalAlignment="Top"
                             materialDesign:HintAssist.Hint="Supplier invoice no."
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding SupplierInvoiceNumber, UpdateSourceTrigger=PropertyChanged}" />

                    <DatePicker Grid.Column="2" VerticalAlignment="Top"
                                materialDesign:HintAssist.Hint="Invoice date"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                SelectedDate="{Binding InvoiceDate}" />
                </Grid>

                <DockPanel Grid.Row="2">
                    <TextBlock DockPanel.Dock="Top" Text="Press Enter on Item to search medicine."
                               FontSize="12" Opacity="0.6" Margin="0,0,0,8" />

                    <DataGrid x:Name="PurchaseGrid"
                          ItemsSource="{Binding Lines}"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          materialDesign:DataGridAssist.CellPadding="8,6"
                          SelectionMode="Single"
                          PreviewKeyDown="PurchaseGrid_PreviewKeyDown"
                          MouseDoubleClick="PurchaseGrid_MouseDoubleClick"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          IsReadOnly="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Item" Width="2*" MinWidth="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" Padding="2,0"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding MedicineName}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                        <Setter Property="Text" Value="Press Enter to search..." />
                                                        <Setter Property="Opacity" Value="0.45" />
                                                        <Setter Property="FontStyle" Value="Italic" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Batch" IsReadOnly="False"
                                            Binding="{Binding BatchNumber, UpdateSourceTrigger=PropertyChanged}" Width="Auto" />
                        <DataGridTemplateColumn Header="Expiry" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <DatePicker SelectedDate="{Binding ExpiryDate, UpdateSourceTrigger=PropertyChanged}"
                                                BorderThickness="0" Width="120" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Qty" Width="Auto" IsReadOnly="False"
                                            Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" />
                        <DataGridTextColumn Header="Free" Width="Auto" IsReadOnly="False"
                                            Binding="{Binding FreeQuantity, UpdateSourceTrigger=PropertyChanged}" />
                        <DataGridTextColumn Header="Cost" Width="Auto" IsReadOnly="False"
                                            Binding="{Binding PurchasePrice, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" />
                        <DataGridTextColumn Header="MRP" Width="Auto" IsReadOnly="False"
                                            Binding="{Binding Mrp, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" />
                        <DataGridTextColumn Header="Sale" Width="Auto" IsReadOnly="False"
                                            Binding="{Binding SellingPrice, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" />
                        <DataGridTextColumn Header="Disc%" Width="Auto" IsReadOnly="False"
                                            Binding="{Binding DiscountPercent, UpdateSourceTrigger=PropertyChanged}" />
                        <DataGridTextColumn Header="GST%" Width="Auto" IsReadOnly="False"
                                            Binding="{Binding GstPercent, UpdateSourceTrigger=PropertyChanged}" />
                        <DataGridTextColumn Header="Amount" IsReadOnly="True" Width="Auto"
                                            Binding="{Binding LineTotal, StringFormat=N2}" />
                        <DataGridTemplateColumn Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Height="28" Width="28"
                                            Command="{Binding DataContext.RemoveLineCommand,
                                                       RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Remove">
                                        <materialDesign:PackIcon Kind="DeleteOutline" Foreground="#E53935" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                </DockPanel>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Column="1" Margin="4" UniformCornerRadius="12" Padding="16"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom">
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Margin="0,0,4,0" Command="{Binding NewPurchaseCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileDocumentPlusOutline" VerticalAlignment="Center" />
                                <TextBlock Text="New (Esc)" Margin="6,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" Margin="4,0,0,0" Command="{Binding SaveCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" />
                                <TextBlock Text="Save (F9)" Margin="6,0,0,0" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#2E7D32"
                               TextWrapping="Wrap" Margin="0,8,0,0"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}" />
                </StackPanel>

                <StackPanel VerticalAlignment="Top">
                    <TextBlock Text="Purchase Summary" FontWeight="SemiBold" Margin="0,0,0,8" />

                    <DockPanel Margin="0,3"><TextBlock Text="Items" DockPanel.Dock="Left" Opacity="0.7" />
                        <TextBlock Text="{Binding ItemCount}" HorizontalAlignment="Right" /></DockPanel>
                    <DockPanel Margin="0,3"><TextBlock Text="Sub Total" DockPanel.Dock="Left" Opacity="0.7" />
                        <TextBlock Text="{Binding SubTotal, Converter={StaticResource Currency}}" HorizontalAlignment="Right" /></DockPanel>
                    <DockPanel Margin="0,3"><TextBlock Text="Discount" DockPanel.Dock="Left" Opacity="0.7" />
                        <TextBlock Text="{Binding DiscountTotal, Converter={StaticResource Currency}}" HorizontalAlignment="Right" /></DockPanel>
                    <DockPanel Margin="0,3"><TextBlock Text="Taxable" DockPanel.Dock="Left" Opacity="0.7" />
                        <TextBlock Text="{Binding TaxableTotal, Converter={StaticResource Currency}}" HorizontalAlignment="Right" /></DockPanel>
                    <DockPanel Margin="0,3"><TextBlock Text="CGST" DockPanel.Dock="Left" Opacity="0.7" />
                        <TextBlock Text="{Binding Cgst, Converter={StaticResource Currency}}" HorizontalAlignment="Right" /></DockPanel>
                    <DockPanel Margin="0,3"><TextBlock Text="SGST" DockPanel.Dock="Left" Opacity="0.7" />
                        <TextBlock Text="{Binding Sgst, Converter={StaticResource Currency}}" HorizontalAlignment="Right" /></DockPanel>
                    <DockPanel Margin="0,3"><TextBlock Text="Round Off" DockPanel.Dock="Left" Opacity="0.7" />
                        <TextBlock Text="{Binding RoundOff, Converter={StaticResource Currency}}" HorizontalAlignment="Right" /></DockPanel>

                    <Separator Margin="0,8" />
                    <DockPanel Margin="0,3">
                        <TextBlock Text="Grand Total" DockPanel.Dock="Left" FontWeight="Bold" FontSize="18" />
                        <TextBlock Text="{Binding GrandTotal, Converter={StaticResource Currency}}"
                                   HorizontalAlignment="Right" FontWeight="Bold" FontSize="18"
                                   Foreground="#00695C" />
                    </DockPanel>

                    <Separator Margin="0,12" />
                    <TextBlock Text="Payment" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <ComboBox materialDesign:HintAssist.Hint="Method"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              ItemsSource="{Binding PaymentMethods}"
                              SelectedItem="{Binding PaymentMethod}" Margin="0,0,0,10" />
                    <TextBox materialDesign:HintAssist.Hint="Amount paid to supplier"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding PaidAmount, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                    <DockPanel Margin="0,3">
                        <TextBlock Text="Balance Due" DockPanel.Dock="Left" Opacity="0.7" />
                        <TextBlock Text="{Binding BalanceDue, Converter={StaticResource Currency}}"
                                   HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="#E53935" />
                    </DockPanel>
                </StackPanel>
            </DockPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
