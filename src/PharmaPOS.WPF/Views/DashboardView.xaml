<UserControl x:Class="PharmaPOS.WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:PharmaPOS.WPF.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <!-- Reusable KPI card style -->
        <Style x:Key="KpiCard" TargetType="materialDesign:Card">
            <Setter Property="UniformCornerRadius" Value="12" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8">
            <DockPanel Margin="8,4,8,16">
                <StackPanel>
                    <TextBlock Text="{Binding Greeting}" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="Here's what's happening in your store today"
                               Opacity="0.6" Margin="0,2,0,0" />
                </StackPanel>
                <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding RefreshCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center" />
                        <TextBlock Text="Refresh" Margin="6,0,0,0" />
                    </StackPanel>
                </Button>
            </DockPanel>

            <!-- Error banner -->
            <materialDesign:Card Background="#FFEBEE" Margin="8,0,8,12" Padding="12"
                                 UniformCornerRadius="8"
                                 Visibility="{Binding LoadError, Converter={StaticResource StringToVisibility}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="#C62828"
                                             VerticalAlignment="Center" />
                    <TextBlock Text="{Binding LoadError}" Foreground="#C62828"
                               TextWrapping="Wrap" Margin="10,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </materialDesign:Card>

            <!-- Primary KPI row -->
            <UniformGrid Columns="4">
                <materialDesign:Card Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <DockPanel>
                            <materialDesign:PackIcon Kind="CashMultiple" Width="26" Height="26"
                                                     Foreground="#26A69A" />
                            <TextBlock Text="Today's Sales" DockPanel.Dock="Right"
                                       HorizontalAlignment="Right" Opacity="0.6" />
                        </DockPanel>
                        <TextBlock Text="{Binding Data.TodaySales, Converter={StaticResource Currency}}"
                                   FontSize="24" FontWeight="Bold" Margin="0,12,0,0" />
                        <TextBlock Text="{Binding Data.TodayInvoices, StringFormat='{}{0} invoices'}"
                                   Opacity="0.6" FontSize="12" Margin="0,2,0,0" />
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <DockPanel>
                            <materialDesign:PackIcon Kind="TruckDelivery" Width="26" Height="26"
                                                     Foreground="#5C6BC0" />
                            <TextBlock Text="Today's Purchase" DockPanel.Dock="Right"
                                       HorizontalAlignment="Right" Opacity="0.6" />
                        </DockPanel>
                        <TextBlock Text="{Binding Data.TodayPurchase, Converter={StaticResource Currency}}"
                                   FontSize="24" FontWeight="Bold" Margin="0,12,0,0" />
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <DockPanel>
                            <materialDesign:PackIcon Kind="AccountGroup" Width="26" Height="26"
                                                     Foreground="#FFA726" />
                            <TextBlock Text="Today's Customers" DockPanel.Dock="Right"
                                       HorizontalAlignment="Right" Opacity="0.6" />
                        </DockPanel>
                        <TextBlock Text="{Binding Data.TodayCustomers}"
                                   FontSize="24" FontWeight="Bold" Margin="0,12,0,0" />
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <DockPanel>
                            <materialDesign:PackIcon Kind="CashRefund" Width="26" Height="26"
                                                     Foreground="#EF5350" />
                            <TextBlock Text="Receivables" DockPanel.Dock="Right"
                                       HorizontalAlignment="Right" Opacity="0.6" />
                        </DockPanel>
                        <TextBlock Text="{Binding Data.PendingReceivables, Converter={StaticResource Currency}}"
                                   FontSize="24" FontWeight="Bold" Margin="0,12,0,0" />
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>

            <!-- Alert KPI row -->
            <UniformGrid Columns="4">
                <materialDesign:Card Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="Low Stock" Opacity="0.6" />
                        <TextBlock Text="{Binding Data.LowStockCount}" FontSize="24"
                                   FontWeight="Bold" Foreground="#FB8C00" Margin="0,12,0,0" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="Near Expiry" Opacity="0.6" />
                        <TextBlock Text="{Binding Data.NearExpiryCount}" FontSize="24"
                                   FontWeight="Bold" Foreground="#FDD835" Margin="0,12,0,0" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="Expired" Opacity="0.6" />
                        <TextBlock Text="{Binding Data.ExpiredCount}" FontSize="24"
                                   FontWeight="Bold" Foreground="#E53935" Margin="0,12,0,0" />
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="Payables" Opacity="0.6" />
                        <TextBlock Text="{Binding Data.PendingPayables, Converter={StaticResource Currency}}"
                                   FontSize="24" FontWeight="Bold" Margin="0,12,0,0" />
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>

            <!-- Lists row -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <materialDesign:Card Grid.Column="0" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="Top Selling Medicines (30 days)"
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                        <ItemsControl ItemsSource="{Binding TopMedicines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,6">
                                        <TextBlock Text="{Binding Name}" />
                                        <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Revenue, StringFormat='{}₹ {0:N2}'}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Grid.Column="1" Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="Monthly Sales (6 months)"
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                        <ItemsControl ItemsSource="{Binding MonthlySales}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,6">
                                        <TextBlock Text="{Binding Month}" Width="90" />
                                        <ProgressBar Value="{Binding Amount, Mode=OneWay}" Maximum="100000"
                                                     Height="8" VerticalAlignment="Center"
                                                     Style="{StaticResource MaterialDesignLinearProgressBar}" />
                                        <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                   Margin="10,0,0,0"
                                                   Text="{Binding Amount, StringFormat='{}₹ {0:N0}'}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
