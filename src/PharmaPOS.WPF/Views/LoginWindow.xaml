<Window x:Class="PharmaPOS.WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:PharmaPOS.WPF.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:LoginViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PharmaPOS - Sign In"
        Height="540" Width="880"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/app.ico"
        ResizeMode="NoResize"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Border CornerRadius="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Branding panel -->
            <Border Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#00695C" Offset="0" />
                        <GradientStop Color="#26A69A" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel VerticalAlignment="Center" Margin="48">
                    <materialDesign:PackIcon Kind="Pill" Width="72" Height="72" Foreground="White" />
                    <TextBlock Text="PharmaPOS" FontSize="40" FontWeight="Bold"
                               Foreground="White" Margin="0,16,0,0" />
                    <TextBlock Text="Pharmacy &amp; Medical Store Management"
                               FontSize="16" Foreground="#E0F2F1" Margin="0,4,0,0" />
                    <TextBlock TextWrapping="Wrap" Margin="0,28,0,0" Foreground="#B2DFDB"
                               Text="Fast billing, batch &amp; expiry tracking, GST invoicing, inventory, accounting and analytics - all in one place." />
                </StackPanel>
            </Border>

            <!-- Login form -->
            <Border Grid.Column="1" Background="{DynamicResource MaterialDesignPaper}">
                <StackPanel VerticalAlignment="Center" Margin="48,0">
                    <TextBlock Text="Welcome back" FontSize="26" FontWeight="Bold" />
                    <TextBlock Text="Sign in to continue" Opacity="0.6" Margin="0,4,0,28" />

                    <TextBox x:Name="UsernameBox"
                             materialDesign:HintAssist.Hint="Username"
                             materialDesign:TextFieldAssist.HasClearButton="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,20" />

                    <PasswordBox x:Name="PasswordBox"
                                 materialDesign:HintAssist.Hint="Password"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 KeyDown="PasswordBox_KeyDown"
                                 Margin="0,0,0,12" />

                    <DockPanel Margin="0,0,0,12">
                        <CheckBox Content="Remember me" IsChecked="{Binding RememberMe}" />
                        <Button Content="Forgot password?" HorizontalAlignment="Right"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Click="ForgotPassword_Click" />
                    </DockPanel>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#D32F2F"
                               TextWrapping="Wrap" Margin="0,0,0,12"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}" />

                    <Button x:Name="LoginButton" Content="SIGN IN"
                            Height="44" Click="LoginButton_Click"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                            Style="{StaticResource MaterialDesignRaisedButton}" />

                    <ProgressBar IsIndeterminate="True" Margin="0,16,0,0"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />

                    <TextBlock Margin="0,24,0,0" Opacity="0.5" FontSize="12" TextAlignment="Center"
                               Text="Default login: admin / Admin@123" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
