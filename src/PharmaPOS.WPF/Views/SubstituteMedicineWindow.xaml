<Window x:Class="PharmaPOS.WPF.Views.SubstituteMedicineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Same Salt &amp; Strength" Height="500" Width="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Substitute Medicines" FontSize="18" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBlock Grid.Row="1"
                   Text="Same salt and strength — select a medicine to replace the current line."
                   Opacity="0.7" Margin="0,0,0,12" TextWrapping="Wrap" />

        <Grid Grid.Row="2" Margin="4,0,4,6" Opacity="0.55">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="280" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="72" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Medicine" FontSize="11" FontWeight="SemiBold" />
            <TextBlock Grid.Column="1" Text="Brand" FontSize="11" FontWeight="SemiBold" Margin="8,0,0,0" />
            <TextBlock Grid.Column="2" Text="MRP" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="8,0,0,0" />
            <TextBlock Grid.Column="3" Text="Stock" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="8,0,0,0" />
        </Grid>

        <ListBox x:Name="MedicineList" Grid.Row="3"
                 ItemsSource="{Binding Medicines}"
                 SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 PreviewKeyDown="MedicineList_PreviewKeyDown"
                 MouseDoubleClick="MedicineList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="2,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="280" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="72" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Medicine.Name}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text=" (current)" FontSize="11" Opacity="0.55" Margin="4,0,0,0"
                                           Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                            <TextBlock Text="{Binding Medicine.GenericName}"
                                       FontSize="11" Opacity="0.65" TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding Medicine.Brand}"
                                   VerticalAlignment="Center"
                                   Opacity="0.85"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="8,0,0,0" />

                        <TextBlock Grid.Column="2"
                                   Text="{Binding Medicine.Mrp, StringFormat=N2}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   FontWeight="SemiBold"
                                   Margin="8,0,0,0" />

                        <TextBlock Grid.Column="3"
                                   Text="{Binding Medicine.TotalStock, StringFormat={}{0:0.##}}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   Opacity="0.75"
                                   Margin="8,0,0,0" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock Text="↑↓ navigate  •  Enter select  •  Esc cancel" Opacity="0.5"
                       VerticalAlignment="Center" Margin="0,0,16,0" FontSize="11" />
            <Button Content="Cancel" Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,0" IsCancel="True" />
            <Button Content="Replace" Style="{StaticResource MaterialDesignRaisedButton}"
                    IsDefault="True" Click="SelectButton_Click" />
        </StackPanel>
    </Grid>
</Window>
